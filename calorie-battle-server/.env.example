# Server
PORT=3000
NODE_ENV=development

# Database (MySQL - production/CI)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=calorie_battle
DB_USER=root
DB_PASS=your_password

# Database (SQLite - local development, used when DB_HOST is not set)
# DB_STORAGE=./data/calorie_battle.db

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
